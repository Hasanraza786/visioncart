# VisionCart API environment configuration.
# Copy to `.env` and adjust. All variables use the VISIONCART_ prefix.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
VISIONCART_ENV=local

# ---------------------------------------------------------------------------
# Database
# Leave DATABASE_URL empty to fall back to a local SQLite file at
# apps/api/data/visioncart.db (great for local dev / tests without Postgres).
# For Postgres use e.g.:
#   postgresql+psycopg://visioncart:visioncart@localhost:5432/visioncart
# ---------------------------------------------------------------------------
VISIONCART_DATABASE_URL=

# ---------------------------------------------------------------------------
# JWT / Auth (BACKEND-OWNED auth — NOT Firebase Auth)
# ALWAYS override VISIONCART_JWT_SECRET in production with a long random value,
# e.g. `openssl rand -hex 48`.
# ---------------------------------------------------------------------------
VISIONCART_JWT_SECRET=dev-insecure-change-me-please-set-a-long-random-value
VISIONCART_ACCESS_TOKEN_TTL_MINUTES=15
VISIONCART_REFRESH_TOKEN_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Admin seed account (created by `python -m visioncart_api.seed`)
# ---------------------------------------------------------------------------
VISIONCART_ADMIN_EMAIL=visioncartadmin@yopmail.com
VISIONCART_ADMIN_PASSWORD=VisionCartAdmin!2026
VISIONCART_ADMIN_NAME=VisionCart Admin

# ---------------------------------------------------------------------------
# CORS — comma separated list of allowed origins, or * for all.
# ---------------------------------------------------------------------------
VISIONCART_CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Social sign-in (backend verifies provider tokens, then issues VisionCart JWT).
# Comma separated audiences. If GOOGLE_CLIENT_IDS is empty the /auth/google
# endpoint returns 503; if APPLE_CLIENT_IDS is empty /auth/apple returns 503.
# Defaults below are the real VisionCart client IDs / bundle (com.visioncart).
# Web client, iOS client, Android client:
# ---------------------------------------------------------------------------
VISIONCART_GOOGLE_CLIENT_IDS=250279750810-ju1f2567c7hhk563vq30lkdorrqrddgs.apps.googleusercontent.com,250279750810-ie9o1qmbvfli9jcef9egsj8p0gtvr7pk.apps.googleusercontent.com,250279750810-fgcfaoebbmrprgt5pnoddv0jg59sqfa2.apps.googleusercontent.com
# Apple audience is the app bundle id / Services ID.
VISIONCART_APPLE_CLIENT_IDS=com.visioncart

# ---------------------------------------------------------------------------
# Object storage (reserved for asset delivery; not required for commerce MVP).
# ---------------------------------------------------------------------------
VISIONCART_STORAGE_ENDPOINT=http://localhost:9000
VISIONCART_STORAGE_BUCKET=visioncart-assets
VISIONCART_STORAGE_ACCESS_KEY=visioncart
VISIONCART_STORAGE_SECRET_KEY=change-me
