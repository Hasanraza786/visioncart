{
  "name": "@visioncart/mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:development": "yarn env:development && react-native run-android",
    "android:staging": "yarn env:staging && react-native run-android",
    "android:production": "yarn env:production && react-native run-android --mode release",
    "env:development": "node scripts/select-environment.mjs development",
    "env:staging": "node scripts/select-environment.mjs staging",
    "env:production": "node scripts/select-environment.mjs production",
    "ios": "react-native run-ios",
    "ios:development": "yarn env:development && react-native run-ios",
    "ios:staging": "yarn env:staging && react-native run-ios",
    "ios:production": "yarn env:production && react-native run-ios --mode Release",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest --no-watchman",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.18.10",
    "@react-navigation/native": "7.3.10",
    "@react-navigation/native-stack": "7.18.2",
    "@tanstack/react-query": "5.101.2",
    "@visioncart/analytics": "workspace:*",
    "@visioncart/contracts": "workspace:*",
    "@visioncart/design-system": "workspace:*",
    "@visioncart/tryon-sdk": "workspace:*",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "4.26.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@visioncart/config-typescript": "workspace:*",
    "@visioncart/eslint-config": "workspace:*",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "test-renderer": "1.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
