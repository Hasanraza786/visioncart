# Android release signing secrets. Copy to `keystore.properties` and fill in.
# This file (the .example) is safe to commit; keystore.properties is git-ignored.
MYAPP_UPLOAD_STORE_FILE=visioncart.keystore
MYAPP_UPLOAD_KEY_ALIAS=visioncart
MYAPP_UPLOAD_STORE_PASSWORD=your-store-password
MYAPP_UPLOAD_KEY_PASSWORD=your-key-password
