{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visioncart.dev/schemas/assets/v1/package.schema.json",
  "title": "VisionCart A0 Asset Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "packageId", "category", "phase", "status", "product",
    "anchors", "license", "files"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "packageId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "category": {"enum": ["glasses", "watch", "ring", "earring", "nose_pin"]},
    "phase": {"const": "A0"},
    "status": {"enum": ["synthetic-draft", "ingest-draft", "production-candidate"]},
    "product": {"const": "product.json"},
    "anchors": {"const": "anchors.json"},
    "license": {"const": "license.json"},
    "files": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "mediaType", "sha256", "bytes", "role", "placeholder"],
        "properties": {
          "path": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"},
          "mediaType": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "bytes": {"type": "integer", "minimum": 1},
          "role": {"enum": ["model-gltf", "model-usdz", "preview"]},
          "placeholder": {"type": "boolean"}
        }
      }
    }
  }
}
