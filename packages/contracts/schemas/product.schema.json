{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visioncart.dev/schemas/assets/v1/product.schema.json",
  "title": "VisionCart A0 Product",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "productId", "name", "category", "dimensionsMm", "synthetic"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "productId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "name": {"type": "string", "minLength": 1, "maxLength": 120},
    "category": {
      "enum": ["glasses", "watch", "ring", "earring", "nose_pin"]
    },
    "dimensionsMm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "depth"],
      "properties": {
        "width": {"type": "number", "exclusiveMinimum": 0},
        "height": {"type": "number", "exclusiveMinimum": 0},
        "depth": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "synthetic": {"type": "boolean"},
    "sourceNote": {"type": "string", "maxLength": 500}
  }
}
