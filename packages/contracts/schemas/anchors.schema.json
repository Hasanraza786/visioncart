{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visioncart.dev/schemas/assets/v1/anchors.schema.json",
  "title": "VisionCart A0 Anchors",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "coordinateSystem", "units", "anchors"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "coordinateSystem": {"const": "right-handed-y-up"},
    "units": {"const": "meters"},
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "position", "rotation"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "position": {
            "type": "array",
            "prefixItems": [{"type": "number"}, {"type": "number"}, {"type": "number"}],
            "items": false
          },
          "rotation": {
            "type": "array",
            "prefixItems": [
              {"type": "number"}, {"type": "number"}, {"type": "number"}, {"type": "number"}
            ],
            "items": false
          }
        }
      }
    }
  }
}
